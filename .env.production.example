POSTGRES_USER=city
POSTGRES_PASSWORD_FILE=./secrets/postgres_password.example.txt
POSTGRES_DB=city_game
REDIS_PASSWORD_FILE=./secrets/redis_password.example.txt
CITY_DATABASE_URL_FILE=./secrets/city_database_url.example.txt
REDIS_URL_FILE=./secrets/redis_url.example.txt
CITY_CORS_ORIGINS=https://game.example.com
CITY_SCHEDULER_LOCK_TTL_SECONDS=60
CITY_SCHEDULER_LOCK_RENEW_SECONDS=15
CITY_SCHEDULER_LOCK_RETRY_SECONDS=5
CITY_LOG_FORMAT=json
CITY_RUN_MIGRATIONS_ON_STARTUP=false
CITY_RELEASE_SHA=replace-with-git-sha
CITY_RELEASE_IMAGE=registry.example.com/ces-backend:replace-with-git-sha
CITY_RELEASE_VERSION=0.3.0
BACKEND_PORT=8000
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD_FILE=./secrets/grafana_admin_password.example.txt
